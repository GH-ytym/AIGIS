AIGIS_APP_NAME=AIGIS Agent
AIGIS_APP_VERSION=0.1.0
AIGIS_API_PREFIX=/v1
AIGIS_HOST=0.0.0.0
AIGIS_PORT=8000

AIGIS_AMAP_API_KEY=
AIGIS_AMAP_BASE_URL=https://restapi.amap.com
AIGIS_AMAP_TIMEOUT_S=6.0
AIGIS_AMAP_RETRY_COUNT=1

AIGIS_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
AIGIS_NOMINATIM_TIMEOUT_S=8.0
AIGIS_NOMINATIM_RETRY_COUNT=1
AIGIS_NOMINATIM_USER_AGENT=aigis-agent
AIGIS_OSRM_BASE_URL=https://router.project-osrm.org
AIGIS_DEFAULT_TRANSPORT_PROFILE=driving
AIGIS_DEFAULT_SEARCH_LIMIT=10

AIGIS_OPENAI_API_KEY=
AIGIS_OPENAI_MODEL=gpt-4o-mini
AIGIS_OPENAI_BASE_URL=
AIGIS_LLM_TEMPERATURE=0.0
AIGIS_LLM_TIMEOUT_S=30.0

AIGIS_POI_AI_REFINE_ENABLED=true
AIGIS_POI_AI_CONFIDENCE_THRESHOLD=0.72
AIGIS_POI_AI_TIMEOUT_S=8.0
AIGIS_POI_AI_RETRY_ZERO_RESULT=true
AIGIS_POI_AI_ALPHA_RESULT_THRESHOLD=3
AIGIS_POI_AI_SPARSE_RESULT_THRESHOLD=2
AIGIS_POI_PARALLEL_RECALL_ENABLED=true
AIGIS_POI_PARALLEL_CITY_SWITCH_MARGIN=0.08
AIGIS_POI_PARALLEL_CITY_SWITCH_MIN_SCORE=0.62
AIGIS_POI_AI_STRONG_LANDMARK_ENABLED=true
AIGIS_POI_AI_STRONG_LANDMARK_CONFIDENCE_THRESHOLD=0.78

AIGIS_SQLITE_URL=sqlite:///data/aigis.db
